    { "id": "consenso",  "label": "Consenso — todos de acuerdo (¿aguanta?)" },
    { "id": "antiferro", "label": "Antiferro — vecinos siempre opuestos" },
    { "id": "espiral",   "label": "Espiral — vórtice de opinión" },
    { "id": "ruido",     "label": "Ruido — caos puro" }
  ],
  "defaultSeed": "gossip",
  "injections": [
