    "REBELLION":    { "default":0.04, "label":"rebeldía",     "min":0.0,  "max":0.3,  "step":0.005},
    "AMPLITUDE":    { "default":0.92, "label":"decaimiento",  "min":0.7,  "max":1.0,  "step":0.005},
    "STUBBORNNESS": { "default":0.3,  "label":"terquedad",    "min":0.0,  "max":1.0,  "step":0.01 },
    "REACH":        { "default":1,    "label":"alcance",      "min":1,    "max":3,    "step":1    },
    "POLARITY":     { "default":1.0,  "label":"polaridad",    "min":-1.0, "max":1.0,  "step":0.1  },
