    { "id": "caos",     "label": "Tres vórtices desfasados (alta entropía)" },
    { "id": "espejos",  "label": "Dos pulsos en fase opuesta (tensión)" },
    { "id": "ruido",    "label": "Ruido puro (entropía máxima)" }
