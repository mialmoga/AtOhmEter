    "S_RADIUS":   { "default":2,    "label":"S radio",     "min":1,    "max":4,    "step":1    },
    "S_GAIN":     { "default":1.2,  "label":"S ganancia",  "min":0.0,  "max":3.0,  "step":0.1  },
    "S_INERTIA":  { "default":0.85, "label":"S inercia",   "min":0.1,  "max":0.99, "step":0.01 },
    "CURIOSITY":  { "default":0.3,  "label":"curiosidad",  "min":0.0,  "max":2.0,  "step":0.05 },
    "ORDER_BIAS": { "default":0.5,  "label":"sesgo orden", "min":0.0,  "max":2.0,  "step":0.05 },
    "DAMP":       { "default":0.9992,"label":"damp",       "min":0.98, "max":1.0,  "step":0.0002},
    "DT":         { "default":0.015,"label":"DT",          "min":0.002,"max":0.04, "step":0.001 },
