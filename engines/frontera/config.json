    "R_CONNECT":   { "default":0.35, "label":"radio conex.", "min":0.1,  "max":0.8,  "step":0.01 },
    "C_THRESH":    { "default":0.3,  "label":"coh. mínima", "min":0.0,  "max":0.9,  "step":0.05 },
    "ATTRACT":     { "default":0.08, "label":"atracción",   "min":0.0,  "max":0.3,  "step":0.01 },
    "REPEL":       { "default":0.12, "label":"repulsión",   "min":0.0,  "max":0.5,  "step":0.01 },
    "PSI_SPEED":   { "default":0.6,  "label":"ψ vel. fase", "min":0.0,  "max":3.0,  "step":0.05 },
    "PSI_COUPLE":  { "default":0.15, "label":"ψ acoplamto","min":0.0,  "max":0.5,  "step":0.01 },
    "BIRTH_RATE":  { "default":0.02, "label":"nacim. rate", "min":0.0,  "max":0.1,  "step":0.005},
    "ISOLATION":   { "default":3,    "label":"min. conex.", "min":0,    "max":10,   "step":1    },
    "FRICTION":    { "default":0.88, "label":"fricción",    "min":0.5,  "max":0.99, "step":0.01 },
    "THRESH":      { "default":0.08, "label":"Umbral 👁",   "min":0.01, "max":1.0,  "step":0.01 }
  },
  "uniformBindings": { "THRESH": "uThresh" },
  "seeds": [
    { "id": "clusters",  "label": "Clusters — 6 grupos en fases distintas" },
    { "id": "nube",      "label": "Nube — dispersión uniforme aleatoria" },
    { "id": "anillo",    "label": "Anillo — toro de puntos en fase helicoidal" },
    { "id": "colision",  "label": "Colisión — dos clusters en trayectoria opuesta" },
    { "id": "espiral",   "label": "Espiral — hélice de puntos en fase giratoria" },
    { "id": "ruido",     "label": "Ruido — nube densa en fases aleatorias" }
  ],
  "defaultSeed": "clusters",
  "injections": [
