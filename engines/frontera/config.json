    { "id": "explosion", "label": "💥 Explosión",  "class": "amber" },
    { "id": "inversion", "label": "⊗ Inversión",  "class": ""      }
  ],
  "gridOptions": [
    { "value": 32, "label": "32³", "default": true },
    { "value": 48, "label": "48³" },
    { "value": 64, "label": "64³" }
  ],
  "hud": [
    { "id": "s-etotal",   "label": "n/N_max",      "class": "hot"  },
    { "id": "s-ekin",      "label": "vel. media",   "class": ""     },
    { "id": "s-etorsion", "label": "conex/punto",  "class": "cool" },
    { "id": "s-ephase",   "label": "|ψ| media",   "class": ""     },
    { "id": "s-helic",    "label": "conex. max",   "class": "cool" },
    { "id": "s-boundary", "label": "aislados",     "class": "hot"  },
    { "id": "s-pump",     "label": "generación",   "class": ""     },
    { "id": "s-coher",    "label": "cohesión",     "class": "cool" }
