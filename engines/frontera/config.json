{
  "id": "frontera",
  "name": "FRONTERA — Geometría Emergente",
  "description": "El espacio no existe hasta que el campo lo decide. Puntos que nacen, se conectan, se mueven y mueren. La geometría es consecuencia de las relaciones, no su causa.",
  "panelTitle": "🕸 FRONTERA",
  "params": {
