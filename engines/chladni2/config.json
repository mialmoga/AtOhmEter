{
  "id": "chladni",
  "name": "CHLADNI 3D — La Forma del Sonido",
  "description": "Tres fuentes pulsan presión real en un sustrato granular. La onda se propaga, rebota e interfiere; donde cabe exactamente en la caja forma ondas estacionarias — los modos propios de la cavidad. La arena huye de donde el medio vibra (antinodos) y queda atrapada donde está quieto (nodos), dibujando las figuras de Chladni en 3D. La estacionariedad no se programa: emerge. Algunas frecuencias resuenan; otras tiemblan. Suena lo que ves.",
  "panelTitle": "🔊 CHLADNI",
  "sound": {
    "enabled": true,
    "voices": 3,
    "startOn": "simulation",
    "bindings": [
      { "freq": "S1_PITCH", "wave": "S1_WAVE", "gain": "S1_GAIN" },
      { "freq": "S2_PITCH", "wave": "S2_WAVE", "gain": "S2_GAIN" },
      { "freq": "S3_PITCH", "wave": "S3_WAVE", "gain": "S3_GAIN" }
    ],
    "freqRange": [80, 880],
    "filterParam": null
  },
  "params": {
    "S1_X":     { "default": 0.5, "label": "F1 · x", "min": 0.0, "max": 1.0, "step": 0.02 },
    "S1_Y":     { "default": 0.5, "label": "F1 · y", "min": 0.0, "max": 1.0, "step": 0.02 },
    "S1_Z":     { "default": 0.5, "label": "F1 · z", "min": 0.0, "max": 1.0, "step": 0.02 },
