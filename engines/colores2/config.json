    "LIGHT_G_X":    { "default":0.0,  "label":"luz G pos X",  "min":-1.0,"max":1.0, "step":0.05  },
    "LIGHT_B_X":    { "default":0.7,  "label":"luz B pos X",  "min":-1.0,"max":1.0, "step":0.05  },
    "LIGHT_SPREAD": { "default":0.6,  "label":"apertura luz", "min":0.1, "max":1.5, "step":0.05  },
